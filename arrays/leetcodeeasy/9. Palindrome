class Solution {
    public boolean isPalindrome(int x) {
        if(x<0)
        {
            return false;
        }
        int original=x;
        int reverse=0;
        while(x>0)
        {
           int digit=x%10;
           reverse = reverse * 10 + digit;
           x=x/10;
        }
       if(original==reverse)
       {
        return true;
       }
       return false;
    }
}


TC=O(log n)
SC=O(1)
n = 1000
≈ 4 operations
