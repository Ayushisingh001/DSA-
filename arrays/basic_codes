 //   10. problem 26 on leetcode -->remove duplicate elements
        class Solution {
        public int removeDuplicates(int[] nums) {
        int n=nums.length;
        if(nums.length==0)
        {
            return 0;
        }
        int j=1;
        for(int i=1;i<n;i++)
        {
           if(nums[i]!=nums[i-1])
           {
            nums[j]=nums[i];
            j++;
           }
        }
           return j;
    }
}



