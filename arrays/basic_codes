//8.find the largest sum contiguous subarray
//kadane's algorithm-->when count becomes negetive make it zero and keep  adding and compare with max
        int arr[]={-2,1,-3,4,-1,2,1,-5,4};
        int n=arr.length;
        int max=arr[0];
        int count=0;
        for(int i=0;i<n;i++)
        {
            if(count<0)
            {
                count=0;
            }
            count=count+arr[i];
            if(count>max)
            {
                max=count;
            }
        }
        System.out.println("max count"+max);
    }


