        int[]arr={1,0,2,1,1,1,2,2,2,0,0,1,0};
        int n=arr.length;
        //min using max heap
        int low=0;
        int high=n-1;
        int mid=0;
        while(mid<=high)
        { if(arr[mid]==0) {
            int temp = arr[low];
            arr[low] = arr[mid];
            arr[mid] = temp;
            low++;
            mid++;
        }
           else if(arr[mid]==1)
        {
            mid++;
        }
           else
        {
            int temp = arr[mid];
            arr[mid] = arr[high];
            arr[high] = temp;
            high--;
        }
        }
        for(int i=0;i<n;i++)
