    1 
   1 1 
  1 2 1 
 1 3 3 1 
1 4 6 4 1 
        int n = 5;
        for (int i = 0; i < n; i++) {
            int num = 1; // first value in every row is 1
            // spaces for alignment (optional)
            for (int s = 1; s < n - i; s++) {
                System.out.print(" ");
            }
            for (int j = 0; j <= i; j++) {
                System.out.print(num + " ");
                // formula to generate next number
                num = num * (i - j) / (j + 1);
            }
            System.out.println();
        }
Time Complexity: O(n²)
Space Complexity: O(1)
