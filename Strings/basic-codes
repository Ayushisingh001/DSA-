//4. Count uppercase and lowercase letters
        String name="AYUshI SinGH";
        int n=name.length();
        int uppercase=0;
        int lowercase=0;
        for(int i=0;i<n;i++)
        {
            char ch=name.charAt(i);
            if(ch>='A' && ch<='Z')
            {
                uppercase++;
            }
            else if(ch>='a' && ch<='z')
            {
                lowercase++;
            }
        }
        System.out.print("uppercase "+uppercase+" lowercase "+lowercase);
TC=O(n)
SC=O(1)



