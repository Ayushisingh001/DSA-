//10.Find the first non-repeating character
//brute force
String word = "hheelo";
int n = word.length();
for(int i = 0; i < n; i++)
{
    int count = 0;
    for(int j = 0; j < n; j++)
    {
        if(word.charAt(i) == word.charAt(j))
        {
            count++;
        }
    }
    if(count == 1)
    {   System.out.println("First non-repeating character: " + word.charAt(i));
        break;
    }
}
TC= O(n²)
SC= O(1)

another approach--->hashmap
         String word = "hheelo";
        int n = word.length();
        HashMap<Character, Integer> map = new HashMap<>();

         for (int i = 0; i < n; i++) {
            char ch = word.charAt(i);
            map.put(ch, map.getOrDefault(ch, 0) + 1);
        }
        for (int i = 0; i < n; i++) {
            char ch = word.charAt(i);

            if (map.get(ch) == 1) {
                System.out.println(ch);
                break;
            }
        }
TC=O(n)
SC=O(n)



